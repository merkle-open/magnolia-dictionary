<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module SYSTEM "module.dtd" >
<module>
    <name>magnolia-dictionary</name>
    <displayName>Dictionary</displayName>
    <description>Dictionary app for label translations.</description>
    <class>com.merkle.oss.magnolia.dictionary.DictionaryModule</class>
    <version>${project.version}</version>

    <components>
        <id>main</id>
        <component>
            <type>info.magnolia.i18nsystem.TranslationService</type>
            <implementation>com.merkle.oss.magnolia.dictionary.i18nsystem.DictionaryTranslationService</implementation>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.i18nsystem.DictionaryTranslationService</type>
            <implementation>com.merkle.oss.magnolia.dictionary.i18nsystem.DictionaryTranslationServiceImpl</implementation>
            <scope>singleton</scope>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.i18nsystem.DictionaryMessageBundlesLoader</type>
            <implementation>com.merkle.oss.magnolia.dictionary.i18nsystem.DictionaryMessageBundlesLoader</implementation>
            <scope>singleton</scope>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.i18nsystem.I18nResourcesProvider</type>
            <implementation>com.merkle.oss.magnolia.dictionary.i18nsystem.DefaultI18nResourcesProvider</implementation>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.util.LocaleUtil</type>
            <implementation>com.merkle.oss.magnolia.dictionary.util.LocaleUtil</implementation>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.util.SiteProvider</type>
            <implementation>com.merkle.oss.magnolia.dictionary.util.SiteProvider</implementation>
            <scope>singleton</scope>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.field.LocationBasedNodeProvider</type>
            <implementation>com.merkle.oss.magnolia.dictionary.field.LocationBasedNodeProvider</implementation>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.i18nsystem.Label$Persistor</type>
            <implementation>com.merkle.oss.magnolia.dictionary.i18nsystem.Label$Persistor</implementation>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.i18nsystem.Label$Factory</type>
            <implementation>com.merkle.oss.magnolia.dictionary.i18nsystem.Label$Factory</implementation>
            <scope>singleton</scope>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.services.importexport.XlsExportService</type>
            <implementation>com.merkle.oss.magnolia.dictionary.services.importexport.XlsExportService</implementation>
            <scope>singleton</scope>
            <lazy>false</lazy>
        </component>
        <component>
            <type>com.merkle.oss.magnolia.dictionary.services.importexport.XlsImportService</type>
            <implementation>com.merkle.oss.magnolia.dictionary.services.importexport.XlsImportService</implementation>
            <scope>singleton</scope>
            <lazy>false</lazy>
        </component>
    </components>

    <components>
        <id>datasource-siteOption</id>
        <component>
            <type>info.magnolia.ui.field.SelectFieldSupport</type>
            <implementation>com.merkle.oss.magnolia.dictionary.field.SiteOptionDatasourceDefinition$SelectFieldSupport</implementation>
        </component>
    </components>

    <dependencies>
        <dependency>
            <name>i18n</name>
            <version>*/*</version>
        </dependency>
        <dependency>
            <name>site</name>
            <version>*</version>
        </dependency>
    </dependencies>

    <repositories>
        <repository>
            <name>magnolia</name>
            <workspaces>
                <workspace>dictionary</workspace>
            </workspaces>
            <nodeTypeFile>/mgnl-nodetypes/magnolia-dictionary-nodetypes.xml</nodeTypeFile>
        </repository>
    </repositories>
</module>
